# ── Bitget API ────────────────────────────────────────────────
BITGET_API_KEY=tu_api_key
BITGET_API_SECRET=tu_api_secret
BITGET_PASSPHRASE=tu_passphrase

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_TOKEN=123456789:ABCdef...     # Token del bot (@BotFather)
TELEGRAM_CHAT_ID=tu_chat_id           # Tu chat ID (@userinfobot)

# ── IA — decisiones de trading ────────────────────────────────
GROQ_API_KEY=tu_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=tu_gemini_key
GEMINI_MODEL=gemini-2.0-flash
AI_MIN_CONFIDENCE=6

# ── Scanner dinámico ──────────────────────────────────────────
MIN_VOLUME_USDT=5000000
MIN_CHANGE_PCT=1.5
TOP_PAIRS=15
SCANNER_REFRESH_MIN=30

# ── Configuración base ────────────────────────────────────────
TIMEFRAME=15m
LEVERAGE=5
MARGIN_MODE=isolated
USDT_PER_TRADE=10

# ── Riesgo global ─────────────────────────────────────────────
MAX_CONCURRENT_TRADES=3
MAX_GLOBAL_DAILY_LOSS_PCT=10.0

# ── Riesgo por par ────────────────────────────────────────────
TP_PCT=4.0
SL_PCT=2.0
TRAILING_SL=true
TRAILING_ACTIVATION_PCT=1.5
TRAILING_CALLBACK_PCT=0.8
MAX_DAILY_LOSS_PCT=5.0

# ── Sistema ───────────────────────────────────────────────────
LOOP_INTERVAL=60
DRY_RUN=true
