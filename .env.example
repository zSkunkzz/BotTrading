# -- Bitget API
BITGET_API_KEY=tu_api_key
BITGET_API_SECRET=tu_api_secret
BITGET_PASSPHRASE=tu_passphrase

# -- Telegram (solo alertas)
TELEGRAM_TOKEN=token_de_tu_bot
TELEGRAM_CHAT_ID=tu_chat_id

# -- Trading
SYMBOL=BTCUSDT
TIMEFRAME=15m
LEVERAGE=5
MARGIN_MODE=isolated
USDT_PER_TRADE=20

# -- Estrategia
ST_ATR_PERIOD=10
ST_FACTOR=3.0
EMA_FAST=21
EMA_SLOW=50
RSI_PERIOD=14
RSI_OB=65
RSI_OS=35
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
MIN_CONFIRMATIONS=3

# -- Riesgo
TP_PCT=4.0
SL_PCT=2.0
TRAILING_SL=true
TRAILING_ACTIVATION_PCT=1.5
TRAILING_CALLBACK_PCT=0.8
MAX_DAILY_LOSS_PCT=5.0
MAX_OPEN_TRADES=1

# -- Sistema
LOOP_INTERVAL=30
HEARTBEAT_EVERY=240
DRY_RUN=true
