# ── Bitget API ──────────────────────────────────────────────
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── IA ──────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=

# ── Trading ─────────────────────────────────────────────────
DRY_RUN=true
LEVERAGE=5
MARGIN_MODE=isolated
USADT_PER_TRADE=10
TIMEFRAME=15m
LOOP_INTERVAL=60

# TP/SL fallback (si no hay niveles ATR)
AI_TP_PCT=3.0
AI_SL_PCT=-1.5

# TP2 parcial: fracción a cerrar cuando se alcanza TP2 (0.5 = 50%)
TP2_PARTIAL_RATIO=0.5

# ── Scanner ─────────────────────────────────────────────────
MIN_VOLUME_USDT=5000000
MIN_CHANGE_PCT=1.5
TOP_PAIRS=15
SCANNER_REFRESH_MIN=30

# ── Risk Global ─────────────────────────────────────────────
MAX_CONCURRENT_TRADES=3
MAX_GLOBAL_DAILY_LOSS_PCT=10.0
MAX_DAILY_LOSS_PCT=5.0

# ── Persistencia (opcional: Railway Volume mount) ───────────
# STATE_FILE=/data/bot_state.json
