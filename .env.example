# ── Hyperliquid ──────────────────────────────────────────────────────────────
# Opción A (recomendada): API Key de agente generada en app.hyperliquid.xyz
HL_API_WALLET_ADDRESS=0xtuwalletprincipal
HL_API_PRIVATE_KEY=0xtuprivatekeydeagente

# Opción B: Private key directa del wallet principal (menos seguro)
# HL_PRIVATE_KEY=0xtuprivatekeyprincipal
# HL_ACCOUNT_ADDR=   # opcional, se deriva automáticamente

HL_TESTNET=false

# ── OKX ──────────────────────────────────────────────────────────────────────
# Genera tus credenciales en: https://www.okx.com/account/my-api
# Permisos necesarios: Trade + Read (NO Withdraw)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
# Sandbox/demo (https://www.okx.com/demo-trading): cambia a true para testear
OKX_TESTNET=false
# Máx. requests info simultáneas (default 4, igual que HL_INFO_CONCURRENCY)
OKX_INFO_CONCURRENCY=4

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── IA ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile

# ── Webhook ─────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=cambia_esto_por_un_secreto_largo
# WEBHOOK_PORT=8080

# ── Estrategia ───────────────────────────────────────────────────────────────
LOOP_INTERVAL=60
TIMEFRAME=15m
MIN_SIGNAL_SCORE=5
MIN_RR_REQUIRED=1.8
SKIP_AI_ON_STRONG=true

# ── Risk management ──────────────────────────────────────────────────────────
USDC_PER_TRADE=10
TP_PCT=4.0
SL_PCT=2.0
TRAILING_SL=true
TRAILING_ACTIVATION_PCT=1.5
TRAILING_CALLBACK_PCT=0.8
MAX_DAILY_LOSS_PCT=5.0
MAX_OPEN_TRADES_PER_SYMBOL=1
MAX_CONCURRENT_TRADES=3
MAX_GLOBAL_DAILY_LOSS_PCT=10.0
TP2_PARTIAL_RATIO=0.5
AI_TP_PCT=3.0
AI_SL_PCT=-1.5
AI_MIN_CONFIDENCE=6

# ── Strategy AI thresholds ───────────────────────────────────────────────────
AI_CALL_MIN_SCORE=6
AI_HOLD_OVERRIDE_SCORE=8
# Si la IA devuelve HOLD con confidence >= este valor, NO se hace override técnico
AI_HIGH_CONFIDENCE_THRESHOLD=8

# ── PreTrade Risk (ajustados para cuentas pequeñas) ───────────────────────
PT_MAX_NOTIONAL_PER_TRADE=200
PT_MAX_SYMBOL_EXPOSURE=200
PT_MAX_TOTAL_EXPOSURE=500
PT_MAX_SPREAD_BPS=30
PT_MIN_SL_DISTANCE_BPS=8
PT_BALANCE_USAGE_PCT=0.90

# ── Scanner ───────────────────────────────────────────────────────────────────
MIN_VOLUME_USDT=5000000
MIN_CHANGE_PCT=1.5
TOP_PAIRS=15
SCANNER_REFRESH_MIN=30
LEVERAGE=5
MARGIN_MODE=isolated

# ── Blacklist de pares (separados por coma, sin espacios) ────────────────────
# SYMBOL_BLACKLIST=ZEC,BSB,TRUMP

# ── Estado persistente ───────────────────────────────────────────────────────
# IMPORTANTE: /tmp se borra en cada restart de Railway.
# Monta un volumen en Railway y usa /data para persistencia real.
STATE_FILE=/data/bot_state.json

# ── Modo simulación ──────────────────────────────────────────────────────────
DRY_RUN=true

# ── Execution Engine ─────────────────────────────────────────────────────────
EE_LIMIT_TIMEOUT_S=4
EE_MAX_SPREAD_BPS_LIMIT=15
EE_LIMIT_OFFSET_BPS=3
EE_MAX_SLIPPAGE_ALERT_BPS=30

# ── Hyperliquid market slippage ───────────────────────────────────────────────
# Slippage máximo aceptado para órdenes de mercado y trigger orders (0.5% por defecto)
HL_MARKET_SLIPPAGE=0.005

# ── v21 — Calidad de señal ────────────────────────────────────────────────────
# Vol mínimo de la vela de señal vs media de N velas anteriores (evita rangos muertos)
# 1.0 = sin filtro; 1.5 = vela de señal debe tener al menos 50% más vol que la media
VOL_SIGNAL_MIN=1.0
# No abrir LONG si funding rate > +0.05% (longs ya sobrepagando)
FUNDING_LONG_MAX=0.0005
# No abrir SHORT si funding rate < -0.05% (shorts ya sobrepagando)
FUNDING_SHORT_MIN=-0.0005

# ── v21 — Persistencia noticias ───────────────────────────────────────────────
# Tiempo en minutos que dura el score_delta de noticias en caché antes de expirar
NEWS_SCORE_TTL_MINUTES=30

# ── v21 — Funding trend ───────────────────────────────────────────────────────
# Número de scans que se acumulan para calcular la tendencia del funding rate
# Con SCANNER_REFRESH_MIN=15, FUNDING_TREND_WINDOW=3 → tendencia de ~45 min
FUNDING_TREND_WINDOW=3
