# ── Bitget API ────────────────────────────────────────────────
BITGET_API_KEY=tu_api_key
BITGET_API_SECRET=tu_api_secret
BITGET_PASSPHRASE=tu_passphrase

# ── IA — decisiones de trading ────────────────────────────────
# La IA decide BUY / SELL / HOLD / CLOSE en cada ciclo
# Fallback automático: Groq → Gemini → reglas técnicas

GROQ_API_KEY=tu_groq_key           # Principal (más rápido)
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=tu_gemini_key       # Fallback automático
GEMINI_MODEL=gemini-2.0-flash

AI_MIN_CONFIDENCE=6    # La IA necesita confianza ≥6/10 para operar (1-10)

# ── Scanner dinámico de pares ─────────────────────────────────
MIN_VOLUME_USDT=5000000
MIN_CHANGE_PCT=1.5
TOP_PAIRS=15
SCANNER_REFRESH_MIN=30

# ── Configuración base ────────────────────────────────────────
TIMEFRAME=15m
LEVERAGE=5
MARGIN_MODE=isolated
USDT_PER_TRADE=10

# ── Riesgo global ─────────────────────────────────────────────
MAX_CONCURRENT_TRADES=3
MAX_GLOBAL_DAILY_LOSS_PCT=10.0

# ── Riesgo por par ────────────────────────────────────────────
TP_PCT=4.0
SL_PCT=2.0
TRAILING_SL=true
TRAILING_ACTIVATION_PCT=1.5
TRAILING_CALLBACK_PCT=0.8
MAX_DAILY_LOSS_PCT=5.0

# ── Sistema ───────────────────────────────────────────────────
LOOP_INTERVAL=60
DRY_RUN=true
