# ── Hyperliquid ────────────────────────────────────────────────────────────────
HYPERLIQUID_PRIVATE_KEY=tu_clave_privada_evm_hex   # con o sin 0x
HYPERLIQUID_WALLET_ADDRESS=                         # opcional, se deriva de la pk
HL_MAINNET=true                                     # false para testnet

# ── Trading ────────────────────────────────────────────────────────────────────
LEVERAGE=10
MARGIN_USDT=20          # margen fijo por operación en USDT
MAX_POSITIONS=7         # máximo de posiciones simultáneas
MAX_SAME_SIDE=4         # máximo de longs o shorts simultáneos
MAX_CORR_PER_GROUP=2    # máximo de posiciones del mismo grupo de correlación

# ── Risk ───────────────────────────────────────────────────────────────────────
DAILY_MAX_LOSS_PCT=-3.0
MAX_DAILY_LOSS_USDT=30

# ── Señales ────────────────────────────────────────────────────────────────────
TIMEFRAME=15m
LOOP_SLEEP=20
WEEKDAY_MIN_SCORE=70
WEEKEND_MIN_SCORE=90
MAX_SPREAD_PCT=0.15

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO          # DEBUG para ver todos los filtros internos

# ── Telegram (opcional) ────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
