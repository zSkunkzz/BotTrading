# ── Bitget ──────────────────────────────────────────────────────────────────
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Groq IA ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Estrategia ───────────────────────────────────────────────────────────────
# Par de ejemplo con USDT (Bitget swap)
SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT
LOOP_INTERVAL=30          # segundos entre scans (recomendado 30)

# Score mínimo para activar cualquier modo de entrada (default 5)
MIN_SIGNAL_SCORE=5
MIN_RR_REQUIRED=1.8

# Si True, el modo STRONG (score>=8) entra directo sin llamar a la IA
SKIP_AI_ON_STRONG=true

# ── Modos de entrada y leverage (rango 5-15x) ────────────────────────────────
# EARLY  (score 5, 4h neutral, 1h+15m alineados) → 5-8x,  size 50%
# NORMAL (score 6-7, todos TF alineados)          → 8-14x, size 100%
# STRONG (score 8+, confluencia máxima)           → 14-15x, size 100%

# ── Risk management (en USDT) ──────────────────────────────────────────────────────
RISK_RATIO=0.08
MIN_TRADE_USDT=2
MAX_TRADE_USDT=15

# Ratio de la posición que se cierra en TP2 (default 50%)
TP2_PARTIAL_RATIO=0.5

# ── Estado persistente ───────────────────────────────────────────────────────
STATE_FILE=/tmp/bot_state.json

# ── Modo simulación ──────────────────────────────────────────────────────────
DRY_RUN=false
