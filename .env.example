# ── Bitget ──────────────────────────────────────────────────────────────────
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── IA ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile

# ── Webhook ──────────────────────────────────────────────────────────────────
# Secret compartido con Bitget y/o TradingView para verificar firma
WEBHOOK_SECRET=cambia_esto_por_un_secreto_largo
# Puerto (Railway lo inyecta automáticamente como PORT, no hace falta tocarlo)
# WEBHOOK_PORT=8080

# ── Estrategia ───────────────────────────────────────────────────────────────
LOOP_INTERVAL=60
TIMEFRAME=15m
MIN_SIGNAL_SCORE=5
MIN_RR_REQUIRED=1.8
SKIP_AI_ON_STRONG=true

# ── Risk management ──────────────────────────────────────────────────────────
USDP_PER_TRADE=10
TP_PCT=4.0
SL_PCT=2.0
TRAILING_SL=true
TRAILING_ACTIVATION_PCT=1.5
TRAILING_CALLBACK_PCT=0.8
MAX_DAILY_LOSS_PCT=5.0
MAX_CONCURRENT_TRADES=3
MAX_GLOBAL_DAILY_LOSS_PCT=10.0
TP2_PARTIAL_RATIO=0.5
AI_TP_PCT=3.0
AI_SL_PCT=-1.5
AI_MIN_CONFIDENCE=6

# ── Scanner ───────────────────────────────────────────────────────────────────
MIN_VOLUME_USDT=5000000
MIN_CHANGE_PCT=1.5
TOP_PAIRS=15
SCANNER_REFRESH_MIN=30
LEVERAGE=5
MARGIN_MODE=isolated

# ── Estado persistente ───────────────────────────────────────────────────────
# Railway Volume montado en /data → cambiar de /tmp a /data para persistencia real
STATE_FILE=/data/bot_state.json

# ── Modo simulación ──────────────────────────────────────────────────────────
DRY_RUN=true
