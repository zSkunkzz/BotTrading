# ── Bitget ──────────────────────────────────────────────────────────────────
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Groq IA ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Estrategia ───────────────────────────────────────────────────────────────
SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT
LOOP_INTERVAL=30          # segundos entre scans (recomendado 30)

# Score mínimo para activar cualquier modo de entrada (default 5)
MIN_SIGNAL_SCORE=5
MIN_RR_REQUIRED=1.8

# Si True, el modo STRONG (score>=8) entra directo sin llamar a la IA
SKIP_AI_ON_STRONG=true

# ── Modos de entrada y leverage (rango 5-20x) ────────────────────────────────
# EARLY  (score 5-6, 4h neutral, 1h+15m alineados) → 5-8x,  size 50%
# NORMAL (score 6-7, todos TF alineados)            → 8-14x, size 100%
# STRONG (score 8+,  confluencia máxima)            → 14-20x, size 100%
#
# El leverage exacto se calcula linealmente dentro del rango de cada modo.
# No es necesario configurar nada; los rangos están en signal_engine.py.

# ── Risk management ──────────────────────────────────────────────────────────
# Ratio del balance a arriesgar por trade (default 8%)
RISK_RATIO=0.08
MIN_TRADE_USDC=2
MAX_TRADE_USDC=15

# Ratio de la posición que se cierra en TP2 (default 50%)
TP2_PARTIAL_RATIO=0.5

# ── Estado persistente ───────────────────────────────────────────────────────
# Ruta del fichero de estado (usa un Volume de Railway para persistencia real)
STATE_FILE=/tmp/bot_state.json

# ── Modo simulación ──────────────────────────────────────────────────────────
DRY_RUN=false
