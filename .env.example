# ── Hyperliquid ──────────────────────────────────────────────────────────────
# Opción A (recomendada): API Key de agente generada en app.hyperliquid.xyz
# La API key es una private key Ethereum separada que firma en nombre de tu wallet
HL_API_WALLET_ADDRESS=0xtuwalletprincipal
HL_API_PRIVATE_KEY=0xtuprivatekeydeagente

# Opción B: Private key directa del wallet principal (menos seguro)
# Usar solo si no tienes API key de agente configurada
# HL_PRIVATE_KEY=0xtuprivatekeyprincipal

# Dirección pública del wallet principal (se deriva automáticamente si no se especifica)
HL_ACCOUNT_ADDR=
# Usar testnet de Hyperliquid (true/false)
HL_TESTNET=false

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── IA ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile

# ── Webhook ──────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=cambia_esto_por_un_secreto_largo
# WEBHOOK_PORT=8080

# ── Estrategia ───────────────────────────────────────────────────────────────
LOOP_INTERVAL=60
TIMEFRAME=15m
MIN_SIGNAL_SCORE=5
MIN_RR_REQUIRED=1.8
SKIP_AI_ON_STRONG=true

# ── Risk management ──────────────────────────────────────────────────────────
USDF_PER_TRADE=10
TP_PCT=4.0
SL_PCT=2.0
TRAILING_SL=true
TRAILING_ACTIVATION_PCT=1.5
TRAILING_CALLBACK_PCT=0.8
MAX_DAILY_LOSS_PCT=5.0
MAX_CONCURRENT_TRADES=3
MAX_GLOBAL_DAILY_LOSS_PCT=10.0
TP2_PARTIAL_RATIO=0.5
AI_TP_PCT=3.0
AI_SL_PCT=-1.5
AI_MIN_CONFIDENCE=6

# ── Scanner ───────────────────────────────────────────────────────────────────
MIN_VOLUME_USDT=5000000
MIN_CHANGE_PCT=1.5
TOP_PAIRS=15
SCANNER_REFRESH_MIN=30
LEVERAGE=5
MARGIN_MODE=isolated

# ── Blacklist de pares (separados por coma, sin espacios) ────────────────────
# SYMBOL_BLACKLIST=ZEC,BSB,TRUMP

# ── Estado persistente ───────────────────────────────────────────────────────
STATE_FILE=/data/bot_state.json

# ── Modo simulación ──────────────────────────────────────────────────────────
DRY_RUN=true

# ── Execution Engine ─────────────────────────────────────────────────────────
EE_LIMIT_TIMEOUT_S=4
EE_MAX_SPREAD_BPS_LIMIT=15
EE_LIMIT_OFFSET_BPS=3
EE_MAX_SLIPPAGE_ALERT_BPS=30
